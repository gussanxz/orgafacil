<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/cor_fundo_header_resumo_contas"
    tools:context=".funcionalidades.mercado.ui.activities.ResumoListaMercadoActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <LinearLayout
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="12dp">

            <ImageView
                android:id="@+id/btnVoltar"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:padding="8dp"
                android:src="@drawable/ic_arrow_back_24"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true"
                app:tint="@color/white" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Lista de Mercado"
                android:textSize="18sp"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:gravity="center"
                android:textAlignment="center"/>

            <ImageView
                android:id="@+id/btnCompartilharTop"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:padding="8dp"
                android:src="@drawable/ic_share_24"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true"
                app:tint="@color/white"
                android:contentDescription="Exportar lista" />

            <LinearLayout
                android:id="@+id/btnHistoricoTop"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:gravity="center"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true"
                android:orientation="vertical">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_historico_24"
                    app:tint="@color/white" />

            </LinearLayout>

        </LinearLayout>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#22FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center_horizontal"
                android:padding="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginStart="8dp"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Orçamento:"
                        android:textColor="@android:color/white"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:alpha="0.9"
                        android:layout_marginEnd="6dp"/>

                    <EditText
                        android:id="@+id/editOrcamentoMaximo"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:minWidth="90dp"
                        android:background="@drawable/bg_input_arredondado"
                        android:inputType="number"
                        android:textColor="@android:color/white"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:hint="0,00"
                        android:textColorHint="#66FFFFFF"
                        android:gravity="center"
                        android:paddingHorizontal="8dp"
                        android:paddingVertical="4dp"
                        android:importantForAutofill="no"
                        android:maxLength="10"
                        android:maxLines="1"
                        android:focusable="false"
                        android:focusableInTouchMode="false"
                        android:cursorVisible="false"/>

                    <ImageView
                        android:id="@+id/imgEditarOrcamento"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_marginStart="6dp"
                        android:src="@drawable/ic_lapis_editar_24"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:clickable="true"
                        android:focusable="true"
                        app:tint="#AAFFFFFF"
                        android:contentDescription="Editar orçamento"/>

                    <View
                        android:layout_width="0dp"
                        android:layout_height="0dp"
                        android:layout_weight="1"/>

                    <LinearLayout
                        android:id="@+id/btnFinalizarLista"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="4dp"
                        android:background="?attr/selectableItemBackground"
                        android:clickable="true"
                        android:focusable="true">

                        <ImageView
                            android:id="@+id/imgFinalizarIcone"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_check_circle_24"
                            app:tint="#81C784" />

                        <TextView
                            android:id="@+id/textFinalizarRotulo"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Finalizar"
                            android:textColor="#81C784"
                            android:textSize="9sp"
                            android:textStyle="bold"
                            android:textAllCaps="true"/>

                    </LinearLayout>

                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#22FFFFFF"
                    android:layout_marginBottom="8dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🛒 No Carrinho"
                        android:textColor="@android:color/white"
                        android:textSize="12sp"
                        android:alpha="0.8"
                        android:layout_marginBottom="0dp"/>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:id="@+id/textTotalCarrinho"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="R$ 0,00"
                            android:textColor="@android:color/white"
                            android:textSize="28sp"
                            android:textStyle="bold"
                            android:maxLines="1"
                            android:ellipsize="end"
                            android:gravity="center"
                            app:autoSizeTextType="uniform"
                            app:autoSizeMinTextSize="20sp"
                            app:autoSizeMaxTextSize="28sp"
                            app:autoSizeStepGranularity="2sp"/>

                        <ImageView
                            android:id="@+id/imgOlhoTotalCarrinho"
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:padding="3dp"
                            android:layout_marginStart="4dp"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:clickable="true"
                            android:focusable="true"
                            android:src="@drawable/ic_visibility_24"
                            app:tint="@color/white"/>
                    </LinearLayout>

                    <TextView
                        android:id="@+id/textSaldoRestante"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Restam R$ 0,00"
                        android:textColor="#81C784"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:maxLines="1"
                        android:ellipsize="end"
                        android:gravity="center"
                        android:layout_marginBottom="6dp" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="4dp">

                    <ProgressBar
                        android:id="@+id/progressBarOrcamento"
                        style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                        android:layout_width="0dp"
                        android:layout_height="2dp"
                        android:layout_weight="1"
                        android:layout_marginStart="16dp"
                        android:progress="0"
                        android:max="100"
                        android:progressDrawable="@drawable/progressbar_orcamento"
                        android:background="@drawable/progressbar_orcamento_bg" />

                    <TextView
                        android:id="@+id/textPercentualOrcamento"
                        android:layout_width="32dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="3dp"
                        android:text="0%"
                        android:textColor="@android:color/white"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:gravity="end"
                        android:alpha="0.9"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginStart="8dp"
                    android:layout_marginTop="2dp">

                    <TextView
                        android:id="@+id/textContagemItens"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="0 itens • 0 no carrinho"
                        android:textColor="@android:color/white"
                        android:textSize="10sp"
                        android:alpha="0.65"
                        android:gravity="start"/>
                </LinearLayout>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <ProgressBar
            android:id="@+id/progressBarResumo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="8dp"
            android:theme="@style/ThemeOverlay.AppCompat.Dark"
            android:visibility="gone" />

        <LinearLayout
            android:id="@+id/scrollMeio"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="@drawable/header_background"
            android:orientation="vertical"
            android:paddingTop="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp"
                android:paddingBottom="12dp"
                android:gravity="center_vertical">

                <androidx.appcompat.widget.SearchView
                    android:id="@+id/searchViewItens"
                    android:layout_width="0dp"
                    android:layout_height="45dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_chip_filtro"
                    android:theme="@style/ThemeOverlay.AppCompat.Light"
                    android:queryHint="Pesquisar item..."
                    app:iconifiedByDefault="false"
                    app:searchIcon="@drawable/ic_search_24"
                    app:queryBackground="@android:color/transparent"/>

                <ImageView
                    android:id="@+id/imgBtnCategoria"
                    android:layout_width="45dp"
                    android:layout_height="45dp"
                    android:layout_marginStart="8dp"
                    android:padding="10dp"
                    android:src="@drawable/ic_list_24"
                    android:background="@drawable/bg_chip_filtro"
                    app:tint="#555555"
                    android:contentDescription="Filtrar por categoria"/>

                <ImageView
                    android:id="@+id/imgBtnLimparFiltro"
                    android:layout_width="45dp"
                    android:layout_height="45dp"
                    android:layout_marginStart="8dp"
                    android:padding="10dp"
                    android:src="@drawable/ic_x_24"
                    android:background="@drawable/bg_chip_filtro"
                    app:tint="#D32F2F"
                    android:visibility="gone"
                    android:contentDescription="Limpar filtro ativo"/>

                <ImageView
                    android:id="@+id/imgBtnOrdenar"
                    android:layout_width="45dp"
                    android:layout_height="45dp"
                    android:layout_marginStart="8dp"
                    android:padding="10dp"
                    android:src="@drawable/ic_filtro_24"
                    android:background="@drawable/bg_chip_filtro"
                    app:tint="#555555"
                    android:contentDescription="Ordenar lista"/>

            </LinearLayout>

            <LinearLayout
                android:id="@+id/layoutChipCategoriaAtiva"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp"
                android:paddingBottom="8dp"
                android:gravity="center_vertical"
                android:visibility="gone">

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipCategoriaAtiva"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Categoria"
                    style="@style/Widget.MaterialComponents.Chip.Filter"
                    app:chipBackgroundColor="@color/chip_background"
                    app:closeIconVisible="true"
                    android:textSize="12sp"/>

            </LinearLayout>

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:clipChildren="false"
                android:clipToPadding="false">

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recyclerViewItens"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:clipToPadding="false"
                    android:paddingBottom="80dp"
                    android:layoutAnimation="@anim/layout_anim_slide_up"/>

                <LinearLayout
                    android:id="@+id/layoutEmptyStateMercado"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="32dp"
                    android:visibility="gone">

                    <ImageView
                        android:id="@+id/imgEmptyStateMercado"
                        android:layout_width="96dp"
                        android:layout_height="96dp"
                        android:layout_marginBottom="16dp"
                        android:src="@drawable/ic_shopping_cart_96"
                        android:alpha="0.2"/>

                    <TextView
                        android:id="@+id/textEmptyStateTitulo"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Sua lista está vazia"
                        android:textAlignment="center"
                        android:textStyle="bold"
                        android:textSize="17sp"
                        android:layout_marginBottom="6dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Toque no + para adicionar produtos"
                        android:textAlignment="center"
                        android:textSize="14sp"
                        android:alpha="0.5"/>

                </LinearLayout>

            </FrameLayout>

        </LinearLayout>

    </LinearLayout>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab_main"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="20dp"
        app:backgroundTint="#FF4081"
        app:fabSize="mini"
        app:srcCompat="@drawable/ic_add_24"
        app:tint="@color/white"
        app:elevation="8dp"
        app:pressedTranslationZ="10dp" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>