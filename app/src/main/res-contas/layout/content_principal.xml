<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical">

    <!-- HEADER MODERNO -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="150dp"
        android:background="@color/colorPrimary"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingTop="12dp"
        android:paddingBottom="12dp">

        <TextView
            android:id="@+id/textSaudacao"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Carregando..."
            android:textColor="@android:color/white"
            android:textSize="18sp"/>

        <LinearLayout
            android:id="@+id/containerSaldoContas"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="4dp"
            android:padding="4dp">

            <ImageView
                android:id="@+id/imgOlhoSaldoContas"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:padding="4dp"
                android:src="@drawable/ic_visibility_24"
                app:tint="@color/white"/>

            <TextView
                android:id="@+id/textSaldo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="R$ 0,00"
                android:textColor="@android:color/white"
                android:textStyle="bold"
                android:textSize="25sp"
                android:maxLines="1"
                android:ellipsize="end"
                android:paddingVertical="4dp"
                android:paddingStart="2dp"
                app:autoSizeTextType="uniform"
                app:autoSizeMinTextSize="14sp"
                app:autoSizeMaxTextSize="44sp"
                app:autoSizeStepGranularity="2sp" />

        </LinearLayout>

        <TextView
            android:id="@+id/textSaldoAtual"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Saldo atual"
            android:textColor="@android:color/white"
            android:textSize="15sp"
            android:layout_marginTop="2dp"/>

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:background="@color/colorPrimary">
        <!-- CHIPS DE FILTRO POR TIPO -->
        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chipGroupFiltroTipo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:paddingVertical="6dp"
            android:background="@color/colorPrimary"
            app:singleSelection="true"
            app:selectionRequired="true"
            app:chipSpacingHorizontal="8dp">

            <com.google.android.material.chip.Chip
                android:id="@+id/chipTodos"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Todos"
                android:checked="true"
                style="@style/Widget.MaterialComponents.Chip.Filter"
                app:chipBackgroundColor="@color/chip_todos_background"
                android:textColor="@color/chip_todos_text"
                app:checkedIconTint="@color/chip_todos_text"/>

            <com.google.android.material.chip.Chip
                android:id="@+id/chipSoReceitas"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Só Receitas"
                style="@style/Widget.MaterialComponents.Chip.Filter"
                app:chipBackgroundColor="@color/chip_background"
                android:textColor="#43A047"
                app:checkedIconTint="#43A047"/>

            <com.google.android.material.chip.Chip
                android:id="@+id/chipSoDespesas"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Só Despesas"
                style="@style/Widget.MaterialComponents.Chip.Filter"
                app:chipBackgroundColor="@color/chip_background"
                android:textColor="#E53935"
                app:checkedIconTint="#E53935"/>

        </com.google.android.material.chip.ChipGroup>

    </LinearLayout>
    <!-- FILTROS DE BUSCA E DATA -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="8dp"
        android:gravity="center_vertical">

        <androidx.appcompat.widget.SearchView
            android:id="@+id/searchViewEventos"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:queryHint="Categoria ou descrição"/>

        <EditText
            android:id="@+id/editDataInicial"
            android:layout_width="100dp"
            android:layout_height="50dp"
            android:layout_marginStart="8dp"
            android:hint="Data Inicial"
            android:focusable="false"
            android:gravity="center"
            android:background="@drawable/bg_chip_filtro"
            android:textSize="15sp"
            android:textColor="#222222"
            android:textColorHint="#888888" />

        <EditText
            android:id="@+id/editDataFinal"
            android:layout_width="100dp"
            android:layout_height="50dp"
            android:layout_marginStart="8dp"
            android:hint="Data Final"
            android:focusable="false"
            android:gravity="center"
            android:background="@drawable/bg_chip_filtro"
            android:paddingHorizontal="8dp"
            android:textSize="15sp"
            android:textColor="#222222"
            android:textColorHint="#888888" />

        <ImageView
            android:id="@+id/imgLimparFiltroData"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:layout_marginStart="8dp"
            android:padding="8dp"
            android:src="@drawable/ic_x_24"
            android:background="@drawable/bg_chip_clear"
            app:tint="@android:color/white"/>

    </LinearLayout>

    <!-- ÁREA DA LISTA -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclesMovimentos"
            android:layout_width="match_parent"
            android:layout_height="match_parent"/>

        <LinearLayout
            android:id="@+id/layoutEmptyStateContas"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="gone"
            android:padding="32dp">

            <ImageView
                android:id="@+id/imgEmptyStateContas"
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:layout_marginBottom="16dp"
                android:src="@drawable/ic_receipt_long_28"/>

            <TextView
                android:id="@+id/textEmptyStateContas"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nenhuma movimentação encontrada"
                android:textAlignment="center"
                android:textStyle="bold"
                android:textSize="18sp"
                android:layout_marginBottom="24dp"/>

            <Button
                android:id="@+id/btnEmptyStateCTA"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Começar agora"
                android:onClick="adicionarDespesa"
                android:hapticFeedbackEnabled="true"/>

        </LinearLayout>

    </FrameLayout>

</LinearLayout>