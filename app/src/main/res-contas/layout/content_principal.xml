<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorPrimary"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingTop="48dp"
        android:paddingBottom="24dp">

        <TextView
            android:id="@+id/textSaudacao"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Olá, Usuário"
            android:textColor="@android:color/white"
            android:textSize="20sp"
            android:alpha="0.9"/>

        <TextView
            android:id="@+id/textoTituloSaldo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Balanço Projetado"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            android:layout_marginTop="12dp"
            android:alpha="0.8"/>

        <LinearLayout
            android:id="@+id/containerSaldoContas"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="4dp"
            android:layout_marginTop="4dp">

            <TextView
                android:id="@+id/textSaldo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="R$ 0,00"
                android:textColor="@android:color/white"
                android:textStyle="bold"
                android:textSize="28sp"
                android:maxLines="1"
                android:ellipsize="end"
                android:paddingVertical="2dp"
                app:autoSizeTextType="uniform"
                app:autoSizeMinTextSize="18sp"
                app:autoSizeMaxTextSize="44sp"
                app:autoSizeStepGranularity="2sp" />

            <ImageView
                android:id="@+id/imgOlhoSaldoContas"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:padding="8dp"
                android:layout_marginStart="4dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true"
                android:src="@drawable/ic_visibility_24"
                app:tint="@color/white"/>
        </LinearLayout>

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chipGroupFiltroTipo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:singleSelection="true"
            app:selectionRequired="true"
            app:chipSpacingHorizontal="8dp">

            <com.google.android.material.chip.Chip
                android:id="@+id/chipTodos"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TODOS"
                android:checked="true"
                style="@style/Widget.MaterialComponents.Chip.Filter"
                app:chipBackgroundColor="@color/chip_todos_background"
                android:textColor="@color/chip_todos_text"
                app:checkedIconTint="@color/chip_todos_text"/>

            <com.google.android.material.chip.Chip
                android:id="@+id/chipSoReceitas"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="RECEITAS"
                style="@style/Widget.MaterialComponents.Chip.Filter"
                app:chipBackgroundColor="@color/chip_background"
                android:textColor="#43A047"
                app:checkedIconTint="#43A047"/>

            <com.google.android.material.chip.Chip
                android:id="@+id/chipSoDespesas"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="DESPESAS"
                style="@style/Widget.MaterialComponents.Chip.Filter"
                app:chipBackgroundColor="@color/chip_background"
                android:textColor="#E53935"
                app:checkedIconTint="#E53935"/>

        </com.google.android.material.chip.ChipGroup>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@drawable/header_background"
        android:orientation="vertical"
        android:paddingTop="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingBottom="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <androidx.appcompat.widget.SearchView
                    android:id="@+id/searchViewEventos"
                    android:layout_width="0dp"
                    android:layout_height="45dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_chip_filtro"
                    android:theme="@style/ThemeOverlay.AppCompat.Light"
                    android:queryHint="Pesquisar..."
                    app:iconifiedByDefault="false"
                    app:queryBackground="@android:color/transparent"/>

                <ImageView
                    android:id="@+id/imgFiltroCategoria"
                    android:layout_width="45dp"
                    android:layout_height="45dp"
                    android:layout_marginStart="8dp"
                    android:padding="10dp"
                    android:src="@drawable/ic_list_24"
                    android:background="@drawable/bg_chip_filtro"
                    app:tint="#555555"
                    android:contentDescription="Filtrar por Categoria"/>

                <ImageView
                    android:id="@+id/imgFiltroCalendario"
                    android:layout_width="45dp"
                    android:layout_height="45dp"
                    android:layout_marginStart="8dp"
                    android:padding="10dp"
                    android:src="@drawable/ic_calendar_month_24"
                    android:background="@drawable/bg_chip_filtro"
                    app:tint="#555555"/>

                <ImageView
                    android:id="@+id/imgLimparFiltroData"
                    android:layout_width="45dp"
                    android:layout_height="45dp"
                    android:layout_marginStart="8dp"
                    android:padding="10dp"
                    android:src="@drawable/ic_x_24"
                    android:background="@drawable/bg_chip_clear"
                    app:tint="@android:color/white"/>
            </LinearLayout>

            <TextView
                android:id="@+id/textPeriodoSelecionado"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:layout_marginStart="4dp"
                android:text="Período: 01/01 a 31/01"
                android:textColor="#4CAF50"
                android:textSize="12sp"
                android:textStyle="bold"
                android:visibility="gone" />

            <EditText android:id="@+id/editDataInicial" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>
            <EditText android:id="@+id/editDataFinal" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>

        </LinearLayout>

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclesMovimentos"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipToPadding="false"
                android:paddingBottom="80dp"
                android:layoutAnimation="@anim/layout_anim_slide_up" />

            <LinearLayout
                android:id="@+id/layoutEmptyStateContas"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center"
                android:visibility="gone"
                android:padding="32dp">

                <ImageView
                    android:id="@+id/imgEmptyStateContas"
                    android:layout_width="120dp"
                    android:layout_height="120dp"
                    android:layout_marginBottom="16dp"
                    android:src="@drawable/ic_receipt_long_28"/>

                <TextView
                    android:id="@+id/textEmptyStateContas"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Nenhuma movimentação encontrada"
                    android:textAlignment="center"
                    android:textStyle="bold"
                    android:textSize="18sp"
                    android:layout_marginBottom="24dp"/>

                <Button
                    android:id="@+id/btnEmptyStateCTA"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Começar agora"
                    android:onClick="adicionarDespesa"
                    android:hapticFeedbackEnabled="true"/>

            </LinearLayout>
        </FrameLayout>
    </LinearLayout>

</LinearLayout>