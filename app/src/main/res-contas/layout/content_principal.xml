<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical">

    <!-- HEADER AZUL -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="130dp"
        android:background="@color/colorPrimary"
        android:gravity="center"
        android:orientation="vertical">

        <TextView
            android:id="@+id/textSaudacao"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Carregando..."
            android:textAlignment="center"
            android:textColor="@android:color/white"
            android:textSize="18sp"/>

        <TextView
            android:id="@+id/textSaldo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="R$ 0,00"
            android:textAlignment="center"
            android:textColor="@android:color/white"
            android:textStyle="bold"
            android:textSize="24sp"/>

        <TextView
            android:id="@+id/textSaldoAtual"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Saldo atual"
            android:textAlignment="center"
            android:textColor="@android:color/white"/>

    </LinearLayout>

    <!-- FILTROS -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="8dp"
        android:gravity="center_vertical">

        <!-- Linha 1: Busca -->
        <androidx.appcompat.widget.SearchView
            android:id="@+id/searchViewEventos"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:queryHint="Categoria ou descrição"/>

        <!-- Linha 2: Datas -->
        <EditText
            android:id="@+id/editDataInicial"
            android:layout_width="100dp"
            android:layout_height="50dp"
            android:layout_marginStart="8dp"
            android:hint="Data Inicial"
            android:focusable="false"
            android:gravity="center"
            android:background="@drawable/bg_chip_filtro"
            android:textSize="15sp"
            android:textColor="#222222"
            android:textColorHint="#888888" />

        <EditText
            android:id="@+id/editDataFinal"
            android:layout_width="100dp"
            android:layout_height="50dp"
            android:layout_marginStart="8dp"
            android:hint="Data Final"
            android:focusable="false"
            android:gravity="center"
            android:background="@drawable/bg_chip_filtro"
            android:paddingHorizontal="8dp"
            android:textSize="15sp"
            android:textColor="#222222"
            android:textColorHint="#888888" />

        <ImageView
            android:id="@+id/imgLimparFiltroData"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:layout_marginStart="8dp"
            android:padding="8dp"
            android:src="@drawable/ic_x_24"
            android:background="@drawable/bg_chip_clear"
            app:tint="@android:color/white"/>

    </LinearLayout>

    <!-- ÁREA DA LISTA -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclesMovimentos"
            android:layout_width="match_parent"
            android:layout_height="match_parent"/>

        <LinearLayout
            android:id="@+id/layoutEmptyStateContas"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="gone"
            android:padding="32dp">

            <ImageView
                android:id="@+id/imgEmptyStateContas"
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:layout_marginBottom="16dp"
                android:src="@drawable/ic_receipt_long_28"/>

            <TextView
                android:id="@+id/textEmptyStateContas"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nenhuma movimentação encontrada"
                android:textAlignment="center"
                android:textStyle="bold"
                android:textSize="18sp"
                android:layout_marginBottom="24dp"/>

            <Button
                android:id="@+id/btnEmptyStateCTA"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Começar agora"
                android:onClick="adicionarDespesa"
                android:hapticFeedbackEnabled="true"/>

        </LinearLayout>

    </FrameLayout>

</LinearLayout>