<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/header_background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Meta de Gastos (Orçamento)"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/cor_texto"
            android:layout_marginBottom="8dp" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <TextView
                        android:id="@+id/textMetaStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="65% consumido"
                        android:textColor="#212121"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:id="@+id/layoutEditarMeta"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:background="?attr/selectableItemBackground"
                        android:padding="4dp"
                        android:clickable="true"
                        android:focusable="true">

                        <TextView
                            android:id="@+id/textMetaRestante"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="R$ 700 restantes"
                            android:textColor="#757575"
                            android:textSize="12sp"
                            android:layout_marginEnd="4dp"/>

                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@drawable/ic_lapis_editar_24"
                            app:tint="#BDBDBD" />
                    </LinearLayout>
                </RelativeLayout>

                <ProgressBar
                    android:id="@+id/progressMetaMensal"
                    style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="12dp"
                    android:layout_marginTop="12dp"
                    android:progress="65"
                    android:progressTint="#2196F3" />

                <TextView
                    android:id="@+id/textMetaProjecao"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Nesse ritmo, você gastará R$ 2.200 até o fim do mês."
                    android:textSize="12sp"
                    android:textColor="#F57C00"
                    android:textStyle="italic" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Gastos por Dia do Mês"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/cor_texto"
            android:layout_marginBottom="8dp" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="300dp"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp">

            <com.github.mikephil.charting.charts.BarChart
                android:id="@+id/barChartDias"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="8dp" />
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>