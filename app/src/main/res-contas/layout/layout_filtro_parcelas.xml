<?xml version="1.0" encoding="utf-8"?>
<HorizontalScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:scrollbars="none"
    android:layout_marginBottom="12dp">

    <com.google.android.material.chip.ChipGroup
        android:id="@+id/chipGroupFiltroStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:singleLine="true"
        app:selectionRequired="true"
        app:singleSelection="true"> <com.google.android.material.chip.Chip
        android:id="@+id/chipFiltroTodos"
        style="@style/Widget.MaterialComponents.Chip.Choice"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:checked="true"
        android:text="Todas"
        android:textSize="12sp" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chipFiltroPago"
            style="@style/Widget.MaterialComponents.Chip.Choice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="✓ Pagas"
            android:textSize="12sp"
            app:chipBackgroundColor="@color/selector_chip_pago_bg"
            app:chipIconTint="@color/selector_chip_pago_text"
            android:textColor="@color/selector_chip_pago_text" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chipFiltroPendente"
            style="@style/Widget.MaterialComponents.Chip.Choice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⏳ Pendentes"
            android:textSize="12sp"
            app:chipBackgroundColor="@color/selector_chip_pendente_bg"
            app:chipIconTint="@color/selector_chip_pendente_text"
            android:textColor="@color/selector_chip_pendente_text" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chipFiltroAtrasado"
            style="@style/Widget.MaterialComponents.Chip.Choice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⚠ Atrasadas"
            android:textSize="12sp"
            app:chipBackgroundColor="@color/selector_chip_atrasado_bg"
            app:chipIconTint="@color/selector_chip_atrasado_text"
            android:textColor="@color/selector_chip_atrasado_text" />

    </com.google.android.material.chip.ChipGroup>
</HorizontalScrollView>