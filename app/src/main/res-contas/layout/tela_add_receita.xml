<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorPrimaryProventos"
    tools:context=".funcionalidades.contas.movimentacoes.ui.activities.ReceitasActivity">

    <!-- HEADER -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="70dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fabVoltar"
            style="@style/NoElevationFab"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:clickable="true"
            android:onClick="retornarPrincipal"
            app:backgroundTint="@color/colorAccentProventos"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:srcCompat="@drawable/ic_arrow_back_48" />

        <TextView
            android:id="@+id/textViewHeader"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:gravity="center"
            android:text="Adicionar Receita"
            android:textAlignment="gravity"
            android:textColor="@color/white"
            android:textSize="20sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@id/fabSuperiorSalvarCategoria"
            app:layout_constraintStart_toEndOf="@+id/fabVoltar"
            app:layout_constraintTop_toTopOf="parent" />

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fabSuperiorSalvarCategoria"
            style="@style/NoElevationFab"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:clickable="true"
            android:onClick="salvarProventos"
            app:backgroundTint="@color/colorAccentProventos"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:srcCompat="@drawable/ic_confirmar_branco_48" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- CONTEÚDO scrollável -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/content"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@drawable/header_background"
        android:fillViewport="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/header">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="100dp">

            <!-- DESCRIÇÃO -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/textInputDescricao"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:paddingLeft="16dp"
                android:paddingRight="16dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:startIconDrawable="@drawable/ic_description_24">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/editDescricao"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Descrição da receita"
                    android:paddingStart="44dp" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- BANNER SÉRIE (gone por padrão) -->
            <LinearLayout
                android:id="@+id/bannerVerSerie"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginTop="8dp"
                android:background="#1A2E7D32"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="10dp"
                android:visibility="gone"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/textInputDescricao">

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:layout_marginEnd="8dp"
                    android:src="@drawable/ic_calendar_month_24"
                    app:tint="#2E7D32" />

                <TextView
                    android:id="@+id/textBannerSerie"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Parcela X de Y — Ver série completa →"
                    android:textColor="#2E7D32"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- VALOR -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/textInputValor"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:paddingLeft="16dp"
                android:paddingRight="16dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/bannerVerSerie"
                app:startIconDrawable="@drawable/ic_moeda_real_24">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/editValor"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Informe um valor"
                    android:inputType="numberDecimal"
                    android:text="0.00" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- CATEGORIA -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/textInputCategoria"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:paddingLeft="16dp"
                android:paddingRight="16dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/textInputValor"
                app:startIconDrawable="@drawable/ic_label_24">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/editCategoria"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:clickable="true"
                    android:focusable="false"
                    android:hint="Categoria"
                    android:paddingStart="44dp" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- DATA -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/textInputData"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:paddingLeft="16dp"
                android:paddingRight="4dp"
                app:layout_constraintEnd_toStartOf="@id/textInputHora"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/textInputCategoria"
                app:startIconDrawable="@drawable/ic_calendar_month_24">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/editData"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Selecione uma data"
                    android:clickable="true"
                    android:focusable="false"
                    android:inputType="none"
                    android:paddingStart="44dp" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- HORA -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/textInputHora"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:paddingLeft="4dp"
                android:paddingRight="16dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@id/textInputData"
                app:layout_constraintTop_toBottomOf="@+id/textInputCategoria"
                app:startIconDrawable="@drawable/ic_relogio_24">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/editHora"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:clickable="true"
                    android:focusable="false"
                    android:inputType="none"
                    android:paddingStart="44dp" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- STATUS PAGO -->
            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/switchStatusPago"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:paddingLeft="32dp"
                android:paddingRight="16dp"
                android:showText="true"
                android:text="Status: OK"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/textInputData" />

            <!-- ══════════════ BLOCO RECORRÊNCIA ══════════════ -->
            <LinearLayout
                android:id="@+id/layoutRecorrencia"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:orientation="vertical"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/switchStatusPago">

                <!-- Checkbox gatilho -->
                <com.google.android.material.checkbox.MaterialCheckBox
                    android:id="@+id/checkboxRepetir"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Repetir lançamento" />

                <!-- Painel expandido -->
                <LinearLayout
                    android:id="@+id/painelRecorrencia"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone"
                    android:layout_marginTop="8dp">

                    <!-- Label -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tipo de repetição"
                        android:textSize="12sp"
                        android:textColor="#666666"
                        android:layout_marginBottom="6dp" />

                    <!-- Chips de tipo -->
                    <com.google.android.material.chip.ChipGroup
                        android:id="@+id/chipGroupTipoRecorrencia"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:singleSelection="true"
                        app:selectionRequired="true"
                        app:chipSpacingHorizontal="4dp"
                        app:chipSpacingVertical="4dp">

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipParcelado"
                            style="@style/Widget.MaterialComponents.Chip.Choice"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:checked="true"
                            android:text="Parcelar" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipSemanal"
                            style="@style/Widget.MaterialComponents.Chip.Choice"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Semanal" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipQuinzenal"
                            style="@style/Widget.MaterialComponents.Chip.Choice"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Quinzenal" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipMensal"
                            style="@style/Widget.MaterialComponents.Chip.Choice"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Mensal" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipCadaXDias"
                            style="@style/Widget.MaterialComponents.Chip.Choice"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="A cada X dias" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipCadaXMeses"
                            style="@style/Widget.MaterialComponents.Chip.Choice"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="A cada X meses" />

                    </com.google.android.material.chip.ChipGroup>

                    <!-- Campo de intervalo (só para "A cada X dias/meses") -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/textInputIntervalo"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:visibility="gone"
                        app:startIconDrawable="@drawable/ic_calendar_month_24">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/editIntervalo"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Intervalo (ex: 3)"
                            android:inputType="number"
                            android:maxLength="3" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Quantidade de repetições -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/textInputMeses"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        app:startIconDrawable="@drawable/ic_calendar_month_24">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/editQtdMeses"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Quantidade de repetições"
                            android:inputType="number"
                            android:maxLength="3" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Data de referência -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/textInputDataReferencia"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        app:startIconDrawable="@drawable/ic_calendar_month_24">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/editDataReferencia"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Iniciar a partir de (opcional)"
                            android:clickable="true"
                            android:focusable="false"
                            android:inputType="none"
                            android:paddingStart="44dp" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Preview da série -->
                    <TextView
                        android:id="@+id/textPreviewRecorrencia"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:background="#F5F5F5"
                        android:padding="10dp"
                        android:text=""
                        android:textColor="#555555"
                        android:textSize="12sp"
                        android:visibility="gone" />

                </LinearLayout>
            </LinearLayout>

            <!-- FAB salvar inferior -->
            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/fabInferiorSalvarCategoria"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="32dp"
                android:layout_marginEnd="24dp"
                android:clickable="true"
                android:onClick="salvarProventos"
                app:backgroundTint="@color/colorAccentProventos"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:srcCompat="@drawable/ic_confirmar_branco_24" />

            <!-- Botão excluir -->
            <ImageButton
                android:id="@+id/btnExcluir"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_marginStart="24dp"
                android:layout_marginBottom="24dp"
                android:background="@drawable/bg_btn_excluir_circular"
                android:contentDescription="Excluir"
                android:elevation="6dp"
                android:src="@drawable/ic_lixeira_excluir_24"
                app:tint="#FFFFFF"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>