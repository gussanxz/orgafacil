<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorPrimaryProventos"
    tools:context=".funcionalidades.contas.movimentacoes.ui.activities.ReceitasActivity">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fabVoltar"
            style="@style/NoElevationFab"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:clickable="true"
            android:onClick="retornarPrincipal"
            app:backgroundTint="@color/colorPrimaryProventos"
            app:tint="@color/white"
            app:elevation="4dp"
            app:layout_constraintBottom_toBottomOf="@+id/textViewHeader"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@+id/textViewHeader"
            app:srcCompat="@drawable/ic_arrow_back_48" />

        <TextView
            android:id="@+id/textViewHeader"
            android:layout_width="0dp"
            android:layout_height="70dp"
            android:gravity="center"
            android:text="Adicionar Receita"
            android:textAlignment="gravity"
            android:textColor="@color/white"
            android:textSize="20sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toStartOf="@id/fabSuperiorSalvarCategoria"
            app:layout_constraintStart_toEndOf="@+id/fabVoltar"
            app:layout_constraintTop_toTopOf="parent" />

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fabSuperiorSalvarCategoria"
            style="@style/NoElevationFab"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:clickable="true"
            android:onClick="salvarProventos"
            app:backgroundTint="@color/colorPrimaryProventos"
            app:tint="@color/white"
            app:elevation="4dp"
            app:layout_constraintBottom_toBottomOf="@+id/textViewHeader"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@+id/textViewHeader"
            app:srcCompat="@drawable/ic_confirmar_branco_48" />

        <LinearLayout
            android:id="@+id/heroValor"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="32dp"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingTop="16dp"
            android:paddingBottom="16dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/textViewHeader">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Valor da receita"
                android:textColor="@color/white"
                android:textSize="13sp"
                android:textStyle="bold"
                android:alpha="0.9"
                android:layout_marginBottom="6dp" />

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/editValor"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@null"
                android:gravity="center"
                android:hint="R$ 0,00"
                android:inputType="numberDecimal"
                android:textColor="@color/white"
                android:textColorHint="#99FFFFFF"
                android:textSize="40sp"
                android:textStyle="bold" />

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <LinearLayout
        android:id="@+id/barraInferior"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="10dp"
        android:paddingBottom="20dp"
        android:background="@color/cor_background"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <ImageButton
            android:id="@+id/btnExcluir"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:background="@drawable/bg_btn_excluir_circular"
            android:contentDescription="Excluir lançamento"
            android:elevation="2dp"
            android:src="@drawable/ic_lixeira_excluir_24"
            android:visibility="gone"
            app:tint="#FFFFFF" />

        <Space
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
            android:id="@+id/fabInferiorSalvarCategoria"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:clickable="true"
            android:onClick="salvarProventos"
            android:text="Salvar"
            android:textColor="@color/white"
            app:backgroundTint="@color/colorAccentProventos"
            app:icon="@drawable/ic_confirmar_branco_24"
            app:iconTint="@color/white" />

    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:id="@+id/content"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@drawable/header_background"
        android:fillViewport="true"
        android:clipToPadding="false"
        app:layout_constraintBottom_toTopOf="@id/barraInferior"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/header">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="24dp"
            android:paddingBottom="32dp">

            <LinearLayout
                android:id="@+id/bannerVerSerie"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:background="#1A2E7D32"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="10dp"
                android:visibility="gone"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:layout_marginEnd="8dp"
                    android:src="@drawable/ic_calendar_month_24"
                    app:tint="#2E7D32" />

                <TextView
                    android:id="@+id/textBannerSerie"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Parcela X de Y — Ver série completa →"
                    android:textColor="#2E7D32"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/textInputValor"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="8dp"
                android:visibility="gone"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/bannerVerSerie"
                app:startIconDrawable="@drawable/ic_moeda_real_24">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/editValorLegado"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Informe um valor"
                    android:inputType="numberDecimal"
                    android:text="0.00" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/textInputDescricao"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/textInputValor"
                app:startIconDrawable="@drawable/ic_description_24">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/editDescricao"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Descrição da receita"
                    android:paddingStart="44dp" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/textInputCategoria"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="12dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/textInputDescricao"
                app:startIconDrawable="@drawable/ic_label_24"
                app:endIconDrawable="@drawable/ic_arrow_back_48"
                app:endIconTint="#AAAAAA">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/editCategoria"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:clickable="true"
                    android:focusable="false"
                    android:hint="Categoria"
                    android:paddingStart="44dp" />
            </com.google.android.material.textfield.TextInputLayout>

            <TextView
                android:id="@+id/labelDataHora"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginTop="20dp"
                android:text="Data e Hora"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@color/cor_texto"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/textInputCategoria" />

            <LinearLayout
                android:id="@+id/linhaDataHora"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="8dp"
                android:baselineAligned="false"
                android:orientation="horizontal"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/labelDataHora">

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/textInputData"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:layout_weight="1"
                    app:startIconDrawable="@drawable/ic_calendar_month_24">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/editData"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:clickable="true"
                        android:focusable="false"
                        android:inputType="none"
                        android:paddingStart="44dp" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/textInputHora"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    app:startIconDrawable="@drawable/ic_relogio_24">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/editHora"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:clickable="true"
                        android:focusable="false"
                        android:inputType="none"
                        android:paddingStart="44dp" />
                </com.google.android.material.textfield.TextInputLayout>
            </LinearLayout>

            <TextView
                android:id="@+id/labelInfoAdicionais"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginTop="20dp"
                android:text="Pagamento"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@color/cor_texto"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/linhaDataHora" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardStatusPago"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="8dp"
                app:cardBackgroundColor="@color/cor_background"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="#E0E0E0"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/labelInfoAdicionais">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="14dp">

                    <ImageView
                        android:id="@+id/iconeStatusPago"
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@drawable/ic_relogio_24"
                        android:layout_marginEnd="12dp"
                        app:tint="@color/colorAccentProventos" />

                    <com.google.android.material.materialswitch.MaterialSwitch
                        android:id="@+id/switchStatusPago"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:showText="true"
                        android:text="Status: OK"
                        android:textColor="@color/cor_texto"
                        android:textSize="14sp" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:id="@+id/labelRecorrencia"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginTop="20dp"
                android:text="Recorrência"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@color/cor_texto"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/cardStatusPago" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardRecorrencia"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="8dp"
                app:cardBackgroundColor="@color/cor_background"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="#E0E0E0"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/labelRecorrencia">

                <LinearLayout
                    android:id="@+id/layoutRecorrencia"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="14dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Repetir lançamento"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:textColor="@color/cor_texto" />

                            <TextView
                                android:id="@+id/textResumoRecorrencia"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Desativado"
                                android:textSize="12sp"
                                android:textColor="#888888"
                                android:layout_marginTop="2dp" />

                        </LinearLayout>

                        <com.google.android.material.materialswitch.MaterialSwitch
                            android:id="@+id/checkboxRepetir"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content" />
                    </LinearLayout>

                    <View
                        android:id="@+id/divisorRecorrencia"
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#E0E0E0"
                        android:visibility="gone" />

                    <LinearLayout
                        android:id="@+id/painelRecorrencia"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="gone"
                        android:paddingHorizontal="16dp"
                        android:paddingBottom="20dp"
                        android:paddingTop="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Como repetir?"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="@color/cor_texto"
                            android:layout_marginBottom="10dp" />

                        <com.google.android.material.chip.ChipGroup
                            android:id="@+id/chipGroupTipoRecorrencia"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            app:singleSelection="true"
                            app:selectionRequired="true"
                            app:chipSpacingHorizontal="6dp"
                            app:chipSpacingVertical="6dp">

                            <com.google.android.material.chip.Chip
                                android:id="@+id/chipSemanal"
                                style="@style/Widget.MaterialComponents.Chip.Choice"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Semanal" />

                            <com.google.android.material.chip.Chip
                                android:id="@+id/chipQuinzenal"
                                style="@style/Widget.MaterialComponents.Chip.Choice"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Quinzenal" />

                            <com.google.android.material.chip.Chip
                                android:id="@+id/chipMensal"
                                style="@style/Widget.MaterialComponents.Chip.Choice"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:checked="true"
                                android:text="Mensal" />

                            <com.google.android.material.chip.Chip
                                android:id="@+id/chipPersonalizado"
                                style="@style/Widget.MaterialComponents.Chip.Choice"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Personalizado" />

                        </com.google.android.material.chip.ChipGroup>

                        <LinearLayout
                            android:id="@+id/painelPersonalizado"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:visibility="gone"
                            android:layout_marginTop="12dp">

                            <View
                                android:layout_width="match_parent"
                                android:layout_height="1dp"
                                android:background="#F0F0F0"
                                android:layout_marginBottom="12dp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Tipo de intervalo"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                android:textColor="@color/cor_texto"
                                android:layout_marginBottom="10dp" />

                            <com.google.android.material.chip.ChipGroup
                                android:id="@+id/chipGroupIntervaloPersonalizado"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                app:singleSelection="true"
                                app:selectionRequired="true"
                                app:chipSpacingHorizontal="6dp">

                                <com.google.android.material.chip.Chip
                                    android:id="@+id/chipCadaXMeses"
                                    style="@style/Widget.MaterialComponents.Chip.Choice"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:checked="true"
                                    android:text="A cada X meses" />

                                <com.google.android.material.chip.Chip
                                    android:id="@+id/chipCadaXDias"
                                    style="@style/Widget.MaterialComponents.Chip.Choice"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="A cada X dias" />

                            </com.google.android.material.chip.ChipGroup>

                            <com.google.android.material.textfield.TextInputLayout
                                android:id="@+id/textInputIntervalo"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="12dp"
                                android:layout_marginBottom="8dp"
                                app:startIconDrawable="@drawable/ic_calendar_month_24">

                                <com.google.android.material.textfield.TextInputEditText
                                    android:id="@+id/editIntervalo"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:hint="Intervalo numérico (ex: 3)"
                                    android:inputType="number"
                                    android:maxLength="3" />
                            </com.google.android.material.textfield.TextInputLayout>

                        </LinearLayout>

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="#F0F0F0"
                            android:layout_marginTop="14dp"
                            android:layout_marginBottom="14dp" />

                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/textInputMeses"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="8dp"
                            app:startIconDrawable="@drawable/ic_calendar_month_24">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/editQtdMeses"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:hint="Quantidade de repetições"
                                android:inputType="number"
                                android:maxLength="3" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/textInputDataReferencia"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            app:startIconDrawable="@drawable/ic_calendar_month_24">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/editDataReferencia"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:hint="Iniciar a partir de (opcional)"
                                android:clickable="true"
                                android:focusable="false"
                                android:inputType="none"
                                android:paddingStart="44dp" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <LinearLayout
                            android:id="@+id/containerPreviewRecorrencia"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:orientation="horizontal"
                            android:background="#F5F5F5"
                            android:visibility="gone">

                            <View
                                android:layout_width="4dp"
                                android:layout_height="match_parent"
                                android:background="@color/colorPrimaryProventos" />

                            <TextView
                                android:id="@+id/textPreviewRecorrencia"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:padding="10dp"
                                android:text=""
                                android:textColor="#555555"
                                android:textSize="12sp" />

                        </LinearLayout>

                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>