<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="8dp"
    android:layout_marginBottom="4dp"
    android:layout_marginTop="2dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="0dp"
    app:strokeColor="#E0E0E0"
    app:strokeWidth="1dp"
    app:cardBackgroundColor="@color/movCardBackground"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingVertical="10dp"
        android:paddingEnd="12dp">

        <!-- Barra colorida lateral -->
        <View
            android:id="@+id/viewIndicadorCor"
            android:layout_width="4dp"
            android:layout_height="0dp"
            android:background="#4CAF50"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>

        <!-- Ícone da categoria -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardIconeConta"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="12dp"
            app:cardBackgroundColor="#E0F2F1"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@id/viewIndicadorCor"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:id="@+id/imageIconeConta"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_label_24"
                app:tint="#009688"/>
        </androidx.cardview.widget.CardView>

        <!-- Botão confirmar (círculo vazio) — ancorado na direita, centralizado verticalmente -->
        <ImageButton
            android:id="@+id/btnConfirmarPagamento"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/bg_quadrado_vazio"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Confirmar pagamento"
            android:scaleType="centerInside"
            android:padding="6dp"
            android:visibility="gone"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"/>

        <!-- Valor -->
        <TextView
            android:id="@+id/textAdapterValor"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="R$ 100,00"
            android:textColor="#00D39E"
            android:textSize="15sp"
            android:textStyle="bold"
            android:layout_marginEnd="8dp"
            app:layout_constraintEnd_toStartOf="@id/btnConfirmarPagamento"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toTopOf="@id/layoutDataHora"/>

        <!-- Data e hora -->
        <LinearLayout
            android:id="@+id/layoutDataHora"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="end"
            android:orientation="horizontal"
            android:layout_marginEnd="8dp"
            app:layout_constraintEnd_toStartOf="@id/btnConfirmarPagamento"
            app:layout_constraintBottom_toBottomOf="@id/textAdapterCategoria"
            app:layout_constraintTop_toTopOf="@id/textAdapterCategoria">

            <TextView
                android:id="@+id/textAdapterData"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="21 jan"
                android:textColor="#9E9E9E"
                android:textSize="11sp"/>

            <TextView
                android:id="@+id/textAdapterSeparador"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="3dp"
                android:text=" • "
                android:textColor="#BDBDBD"
                android:textSize="11sp"/>

            <TextView
                android:id="@+id/textAdapterHora"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="12:00"
                android:textColor="#9E9E9E"
                android:textSize="11sp"/>
        </LinearLayout>

        <!-- Título -->
        <TextView
            android:id="@+id/textAdapterTitulo"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="8dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="Título da Conta"
            android:textColor="?attr/colorOnSurface"
            android:textSize="15sp"
            android:textStyle="bold"
            app:layout_constraintStart_toEndOf="@id/cardIconeConta"
            app:layout_constraintEnd_toStartOf="@id/textAdapterValor"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toTopOf="@id/textAdapterCategoria"
            app:layout_constraintVertical_chainStyle="packed"/>

        <!-- Categoria -->
        <TextView
            android:id="@+id/textAdapterCategoria"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginTop="2dp"
            android:layout_marginEnd="8dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="Categoria"
            android:textColor="#757575"
            android:textSize="13sp"
            app:layout_constraintStart_toEndOf="@id/cardIconeConta"
            app:layout_constraintEnd_toStartOf="@id/layoutDataHora"
            app:layout_constraintTop_toBottomOf="@id/textAdapterTitulo"
            app:layout_constraintBottom_toBottomOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>