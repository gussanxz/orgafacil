<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="24dp">

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="@android:color/white"
        app:cardCornerRadius="24dp"
        app:cardElevation="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="24dp">

            <View
                android:id="@+id/viewFundoIcone"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:background="@drawable/bg_btn_excluir_circular"
                android:backgroundTint="#E3F2FD"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <ImageView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_categorias_geral_24"
                app:tint="#1976D2"
                app:layout_constraintBottom_toBottomOf="@id/viewFundoIcone"
                app:layout_constraintEnd_toEndOf="@id/viewFundoIcone"
                app:layout_constraintStart_toStartOf="@id/viewFundoIcone"
                app:layout_constraintTop_toTopOf="@id/viewFundoIcone" />

            <TextView
                android:id="@+id/textTituloDialog"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Filtrar por Categoria"
                android:textColor="#212121"
                android:textSize="18sp"
                android:textStyle="bold"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/viewFundoIcone" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerCategoriasDialog"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:layout_constrainedHeight="true"
                app:layout_constraintHeight_max="300dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/textTituloDialog" />

            <LinearLayout
                android:id="@+id/layoutBotoesDialog"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="horizontal"
                android:gravity="center"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/recyclerCategoriasDialog">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnCancelarDialog"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:text="Cancelar"
                    android:textColor="#757575"
                    app:cornerRadius="12dp"
                    android:backgroundTint="#F5F5F5" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnAplicarFiltro"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:text="Aplicar"
                    android:textColor="@android:color/white"
                    app:cornerRadius="12dp"
                    android:backgroundTint="#FF7043" />

            </LinearLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>

    </com.google.android.material.card.MaterialCardView>
</androidx.constraintlayout.widget.ConstraintLayout>