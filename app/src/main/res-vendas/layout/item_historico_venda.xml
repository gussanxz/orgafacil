<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardCornerRadius="14dp"
    app:cardElevation="1dp"
    app:strokeColor="@color/cor_divisor"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <!-- Linha 1: número + status -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/txtVendaId"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Venda #0000000"
                android:textColor="@color/cor_texto_primario"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtVendaStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_status_ativo"
                android:paddingHorizontal="8dp"
                android:paddingVertical="3dp"
                android:text="FINALIZADA"
                android:textColor="#2E7D32"
                android:textSize="11sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Linha 2: horário -->
        <TextView
            android:id="@+id/txtVendaData"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="00:00"
            android:textColor="@color/cor_texto_secundario"
            android:textSize="13sp" />

        <!-- Linha 3: pagamento -->
        <TextView
            android:id="@+id/txtVendaPagamento"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Pagamento: PIX"
            android:textColor="@color/cor_texto_secundario"
            android:textSize="13sp" />

        <!-- Linha 4: qtd + total + botões -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/txtVendaQuantidade"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="1 item"
                android:textColor="@color/cor_texto_primario"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/txtVendaTotal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="R$ 0,00"
                android:textColor="@color/colorPrimary"
                android:textSize="16sp"
                android:textStyle="bold" />

            <!-- Botão editar -->
            <ImageButton
                android:id="@+id/btnEditarVenda"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_marginStart="12dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Editar venda"
                android:src="@drawable/ic_lapis_editar_24"
                android:tint="@color/colorPrimary" />

            <!-- Botão alternar status (ícone muda via código) -->
            <ImageButton
                android:id="@+id/btnAlternarStatus"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_marginStart="4dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Alternar status"
                android:src="@drawable/ic_delete_forever_24"
                android:tint="#C62828" />

        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>