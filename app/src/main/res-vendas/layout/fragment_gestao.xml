<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="8dp"
    android:background="@android:color/transparent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:baselineAligned="false">

        <FrameLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_margin="4dp"
            android:background="@drawable/fundo_arredondado"
            android:clipToOutline="true">

            <LinearLayout
                android:id="@+id/cardVendas"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@drawable/ic_monitoring_28"
                    android:layout_gravity="center"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="VENDAS"
                    android:textColor="@android:color/black"
                    android:textStyle="bold"
                    android:textSize="12sp"
                    android:gravity="center"
                    android:layout_marginBottom="16dp"
                    android:lines="3" />
            </LinearLayout>
        </FrameLayout>

        <FrameLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_margin="4dp"
            android:background="@drawable/fundo_arredondado"
            android:clipToOutline="true">

            <LinearLayout
                android:id="@+id/cardEstoque"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <ImageView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@drawable/ic_inventory_28"
                    android:layout_gravity="center"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="ESTOQUE"
                    android:textColor="@android:color/black"
                    android:textStyle="bold"
                    android:textSize="12sp"
                    android:gravity="center"
                    android:layout_marginBottom="16dp"
                    android:lines="3" />
            </LinearLayout>

            <ImageView
                android:id="@+id/overlayEstoque"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="#CC000000"
                android:src="@drawable/ic_lock_24"
                android:scaleType="center"
                app:tint="@android:color/white"
                android:visibility="visible"
                android:elevation="10dp"
                android:clickable="true"
                android:focusable="true"/>
        </FrameLayout>

        <FrameLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_margin="4dp"
            android:background="@drawable/fundo_arredondado"
            android:clipToOutline="true">
            <LinearLayout
                android:id="@+id/cardDevolucoes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <ImageView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@drawable/ic_assignment_return_28"
                    android:layout_gravity="center"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="DEVOLUÇÕES"
                    android:textColor="@android:color/black"
                    android:textStyle="bold"
                    android:textSize="12sp"
                    android:gravity="center"
                    android:layout_marginBottom="16dp"
                    android:lines="3" />
            </LinearLayout>

            <ImageView
                android:id="@+id/overlayDevolucoes"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="#CC000000"
                android:src="@drawable/ic_lock_24"
                android:scaleType="center"
                app:tint="@android:color/white"
                android:visibility="visible"
                android:elevation="10dp"
                android:clickable="true"
                android:focusable="true"/>
        </FrameLayout>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="8dp"
        android:baselineAligned="false">

        <FrameLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_margin="4dp"
            android:background="@drawable/fundo_arredondado"
            android:clipToOutline="true">
            <LinearLayout
                android:id="@+id/cardRelatorios"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <ImageView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@drawable/ic_analytics_28"
                    android:layout_gravity="center"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="RELATÓRIOS"
                    android:textColor="@android:color/black"
                    android:textStyle="bold"
                    android:textSize="12sp"
                    android:gravity="center"
                    android:layout_marginBottom="16dp"
                    android:lines="3" />
            </LinearLayout>

            <ImageView
                android:id="@+id/overlayRelatorios"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="#CC000000"
                android:src="@drawable/ic_lock_24"
                android:scaleType="center"
                app:tint="@android:color/white"
                android:visibility="visible"
                android:elevation="10dp"
                android:clickable="true"
                android:focusable="true"/>
        </FrameLayout>

        <FrameLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_margin="4dp"
            android:background="@drawable/fundo_arredondado"
            android:clipToOutline="true">
            <LinearLayout
                android:id="@+id/cardControleCaixa"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <ImageView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@drawable/ic_point_of_sale_28"
                    android:layout_gravity="center"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="CONTROLE\nDE CAIXA"
                    android:textColor="@android:color/black"
                    android:textStyle="bold"
                    android:textSize="12sp"
                    android:gravity="center"
                    android:layout_marginBottom="16dp"
                    android:lines="3" />
            </LinearLayout>

            <ImageView
                android:id="@+id/overlayControleCaixa"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="#CC000000"
                android:src="@drawable/ic_lock_24"
                android:scaleType="center"
                app:tint="@android:color/white"
                android:visibility="visible"
                android:elevation="10dp"
                android:clickable="true"
                android:focusable="true"/>
        </FrameLayout>

        <FrameLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_margin="4dp"
            android:background="@drawable/fundo_arredondado"
            android:clipToOutline="true">
            <LinearLayout
                android:id="@+id/cardFinanceiro"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <ImageView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@drawable/ic_paid_28"
                    android:layout_gravity="center"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="FINANCEIRO"
                    android:textColor="@android:color/black"
                    android:textStyle="bold"
                    android:textSize="12sp"
                    android:gravity="center"
                    android:layout_marginBottom="16dp"
                    android:lines="3" />
            </LinearLayout>

            <ImageView
                android:id="@+id/overlayFinanceiro"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="#CC000000"
                android:src="@drawable/ic_lock_24"
                android:scaleType="center"
                app:tint="@android:color/white"
                android:visibility="visible"
                android:elevation="10dp"
                android:clickable="true"
                android:focusable="true"/>
        </FrameLayout>
    </LinearLayout>
</LinearLayout>