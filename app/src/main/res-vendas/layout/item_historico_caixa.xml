<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardCornerRadius="14dp"
    app:cardElevation="1dp"
    app:strokeColor="@color/cor_divisor"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <!-- Linha 1: data + badge de status -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/txtCaixaData"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="dd/MM/yyyy"
                android:textColor="@color/cor_texto_primario"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtCaixaStatusBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingHorizontal="8dp"
                android:paddingVertical="3dp"
                android:text="FECHADO"
                android:textSize="11sp"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- Linha 2: horário de abertura → fechamento -->
        <TextView
            android:id="@+id/txtCaixaHorarios"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:drawablePadding="6dp"
            android:text="Abertura: 08:00  →  Fechamento: 18:00"
            android:textColor="@color/cor_texto_secundario"
            android:textSize="13sp" />

        <!-- Linha 3: observação (ocultada se vazia) -->
        <TextView
            android:id="@+id/txtCaixaObservacao"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:text=""
            android:textColor="@color/cor_texto_secundario"
            android:textSize="12sp"
            android:visibility="gone" />

        <!-- Linha 4: lançamento tardio (ocultado se false) -->
        <TextView
            android:id="@+id/txtLancamentoTardio"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:background="@drawable/bg_chip_filtro"
            android:paddingHorizontal="8dp"
            android:paddingVertical="2dp"
            android:text="Lançamento tardio ativo"
            android:textSize="11sp"
            android:visibility="gone" />

        <!-- Divisor -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginVertical="10dp"
            android:background="@color/cor_divisor" />

        <!-- Linha 5: totais do fechamento -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/txtCaixaQtdVendas"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="0 venda(s)"
                android:textColor="@color/cor_texto_primario"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/txtCaixaTotal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="R$ 0,00"
                android:textColor="@color/colorPrimary"
                android:textSize="16sp"
                android:textStyle="bold" />

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
