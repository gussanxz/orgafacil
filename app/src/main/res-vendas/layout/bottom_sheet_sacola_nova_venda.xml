<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_sacola"
    android:orientation="vertical">

    <!-- Handle visual do bottom sheet -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="8dp"
        android:background="#CCCCCC" />

    <!-- Header do modal -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingBottom="8dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sacola da venda"
                android:textColor="@color/cor_texto_primario"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtQtdItensSacola"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="0 itens"
                android:textColor="@color/cor_texto_secundario"
                android:textSize="13sp" />
        </LinearLayout>

        <ImageButton
            android:id="@+id/btnFecharSacola"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/fundo_arredondado"
            android:backgroundTint="#F5F5F5"
            android:src="@drawable/ic_x_24"
            android:contentDescription="Fechar"
            android:tint="#616161" />
    </LinearLayout>

    <!-- Divisor -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/cor_divisor"
        android:layout_marginBottom="8dp" />

    <!-- Estado vazio -->
    <TextView
        android:id="@+id/txtEstadoVazioSacola"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:gravity="center"
        android:paddingVertical="24dp"
        android:text="Nenhum item na sacola."
        android:textColor="#9E9E9E"
        android:textSize="14sp"
        android:visibility="gone" />

    <!-- Lista de itens (scrollável) -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvItensSacola"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="4dp"
        android:paddingHorizontal="16dp"
        android:clipToPadding="false" />

    <!-- Rodapé: Total + botão COBRAR -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="24dp">

        <!-- Divisor acima do total -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/cor_divisor"
            android:layout_marginBottom="12dp" />

        <!-- Linha de total -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Total"
                android:textColor="@color/cor_texto_primario"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtTotalSacolaBottom"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="R$&#160;0,00"
                android:textColor="@color/colorPrimary"
                android:textSize="20sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Botão COBRAR — exclusivo dentro do modal da sacola -->
        <LinearLayout
            android:id="@+id/btnCobrar"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@drawable/fundo_arredondado"
            android:backgroundTint="@color/colorPrimary"
            android:orientation="horizontal"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_marginEnd="8dp"
                android:src="@drawable/ic_paid_28"
                app:tint="#FFFFFF" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="COBRAR"
                    android:textColor="#FFFFFF"
                    android:textSize="11sp"
                    android:letterSpacing="0.1"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/txtCobrarTotal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="R$&#160;0,00"
                    android:textColor="#FFFFFF"
                    android:textSize="17sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>

</LinearLayout>