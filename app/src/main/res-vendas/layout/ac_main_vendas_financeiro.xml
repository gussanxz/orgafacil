<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/rootFinanceiro"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/colorPrimary">

    <!-- Header: título + total geral -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingTop="16dp"
        android:paddingBottom="12dp">

        <ImageButton
            android:id="@+id/btnVoltarFinanceiro"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@android:color/transparent"
            android:contentDescription="Voltar"
            android:src="@drawable/ic_arrow_back_48"
            app:tint="@color/white" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Financeiro"
                android:textColor="@color/white"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtTotalVendido"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Total: R$ 0,00"
                android:textColor="#CCFFFFFF"
                android:textSize="13sp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Corpo com fundo arredondado -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="@drawable/header_background"
        android:paddingTop="12dp">

        <!-- Filtros rápidos de status -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="16dp"
            android:paddingBottom="8dp"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/chipFinTodasF"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/fundo_arredondado"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="7dp"
                    android:text="Todas"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:id="@+id/chipFinFinalizadas"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/fundo_arredondado"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="7dp"
                    android:text="Finalizadas"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:id="@+id/chipFinCanceladas"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/fundo_arredondado"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="7dp"
                    android:text="Canceladas"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:clickable="true"
                    android:focusable="true" />

            </LinearLayout>
        </HorizontalScrollView>

        <!-- Painel de filtros avançados -->
        <LinearLayout
            android:id="@+id/painelFiltrosAvancados"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingBottom="8dp">

            <!-- Linha 1: pagamento + tipo -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <!-- Filtro: forma de pagamento -->
                <Spinner
                    android:id="@+id/spinnerPagamento"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/fundo_arredondado"
                    android:paddingHorizontal="12dp"
                    android:spinnerMode="dropdown" />

                <!-- Filtro: produto ou serviço -->
                <Spinner
                    android:id="@+id/spinnerTipoItem"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:background="@drawable/fundo_arredondado"
                    android:paddingHorizontal="12dp"
                    android:spinnerMode="dropdown" />

            </LinearLayout>

            <!-- Linha 2: intervalo de datas -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="8dp">

                <TextView
                    android:id="@+id/btnDataInicial"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/fundo_arredondado"
                    android:paddingHorizontal="12dp"
                    android:gravity="center_vertical"
                    android:text="Data inicial"
                    android:textColor="@color/cor_texto_secundario"
                    android:textSize="13sp"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:id="@+id/btnDataFinal"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/fundo_arredondado"
                    android:paddingHorizontal="12dp"
                    android:gravity="center_vertical"
                    android:text="Data final"
                    android:textColor="@color/cor_texto_secundario"
                    android:textSize="13sp"
                    android:clickable="true"
                    android:focusable="true" />

                <!-- Botão X: limpar filtros -->
                <ImageButton
                    android:id="@+id/btnLimparFiltros"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/fundo_arredondado"
                    android:src="@drawable/bg_chip_clear"
                    android:contentDescription="Limpar filtros"
                    android:visibility="gone" />

            </LinearLayout>

        </LinearLayout>

        <!-- Header do dia congelado (sticky) -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardHeaderDiaCongelado"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="4dp"
            android:visibility="gone"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="@color/cardDiaBackground">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/colorPrimary"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp"
                android:paddingVertical="10dp">

                <TextView
                    android:id="@+id/txtHeaderDiaCongelado"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Hoje"
                    android:textColor="@color/white"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/txtTotalDiaCongelado"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#CCFFFFFF"
                    android:textSize="13sp"
                    android:textStyle="bold" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Estado vazio -->
        <LinearLayout
            android:id="@+id/layoutEstadoVazioFinanceiro"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="40dp"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:visibility="gone">

            <ImageView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_paid_28"
                app:tint="#9E9E9E" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Nenhuma venda encontrada"
                android:textColor="@color/cor_texto_primario"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:gravity="center"
                android:text="Ajuste os filtros ou registre vendas para ver aqui."
                android:textColor="@color/cor_texto_secundario"
                android:textSize="14sp" />
        </LinearLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvFinanceiro"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:paddingHorizontal="16dp"
            android:paddingTop="4dp"
            android:paddingBottom="16dp" />

    </LinearLayout>
</LinearLayout>